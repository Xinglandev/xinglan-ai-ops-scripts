# 应用基础配置
APP_NAME="legacy-application-staging"
APP_VERSION="0.8.4"
APP_ENV="staging"
APP_DEBUG="true"
APP_URL="https://staging-legacy.company.com"
APP_TIMEZONE="Asia/Shanghai"
APP_LOCALE="zh_CN"
APP_FALLBACK_LOCALE="en"

# 服务器配置
SERVER_HOST="0.0.0.0"
SERVER_PORT="8080"
WORKER_PROCESSES="4"
MAX_REQUESTS="1000"
REQUEST_TIMEOUT="30"
KEEPALIVE_TIMEOUT="15"

# 数据库连接 - MySQL
DB_CONNECTION="mysql"
DB_HOST="mysql-staging-cluster.internal.company.com"
DB_PORT="3306"
DB_DATABASE="app_legacy_staging"
DB_USERNAME="app_user_staging_rw"
DB_PASSWORD="St@gingDbP@ssw0rd!2024"
DB_CHARSET="utf8mb4"
DB_COLLATION="utf8mb4_unicode_ci"
DB_PREFIX="legacy_"
DB_STRICT="false"
DB_ENGINE="InnoDB"
DB_MAX_CONNECTIONS="100"
DB_CONNECTION_TIMEOUT="10"

# 数据库从库（只读）
DB_READ_HOST="mysql-staging-replica.internal.company.com"
DB_READ_PORT="3306"
DB_READ_USERNAME="app_user_staging_ro"
DB_READ_PASSWORD="R0nlyP@ss!2024"

# Redis缓存配置
REDIS_HOST="redis-staging-cluster.internal.company.com"
REDIS_PORT="6379"
REDIS_PASSWORD="Redis$taging123!Cache"
REDIS_DB="0"
REDIS_PREFIX="legacy:staging:"
REDIS_TIMEOUT="5"
REDIS_RETRY_INTERVAL="100"
REDIS_READ_TIMEOUT="3"

# Redis哨兵配置（如果启用）
