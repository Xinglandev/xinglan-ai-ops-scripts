LOG_FILE_MAX_DAYS="30"

# 监控和指标
METRICS_ENABLED="true"
METRICS_ENDPOINT="http://monitor-staging.internal.company.com:9090"
METRICS_NAMESPACE="legacy_app_staging"
METRICS_JOB="legacy_backend"
METRICS_INTERVAL="15"
METRICS_TIMEOUT="5"

# 分布式追踪
TRACING_ENABLED="true"
TRACING_PROVIDER="jaeger"
TRACING_ENDPOINT="http://jaeger-staging.internal.company.com:14268"
TRACING_SAMPLING_RATE="0.1"
TRACING_SERVICE_NAME="legacy-app-staging"

# 性能配置
CACHE_TTL="3600"
SESSION_LIFETIME="120"
SESSION_ENCRYPT="true"
SESSION_SECURE_COOKIE="false"
QUEUE_WORKERS="4"
QUEUE_MAX_TRIES="3"
QUEUE_TIMEOUT="60"

# 安全配置（测试环境降低要求）
APP_KEY="base64:stagingExampleKey1234567890abcdefghijklmn="
JWT_SECRET="stagingJwtSecretExample4567890"
ENCRYPTION_KEY="stagingEncryptionKeyExample123"
CIPHER="AES-256-CBC"
ALLOWED_ORIGINS="https://staging-legacy.company.com,http://localhost:3000"
CSP_ENABLED="false"
HSTS_ENABLED="false"

# 第三方服务集成
GOOGLE_MAPS_API_KEY="AIzaStagingExampleKey123456789"
RECAPTCHA_SITE_KEY="6LeStagingExampleSiteKey123456"
RECAPTCHA_SECRET_KEY="6LeStagingExampleSecretKey123456"
STRIPE_PUBLIC_KEY="pk_test_51Example1234567890"
STRIPE_SECRET_KEY="sk_test_51Example1234567890"

# 业务配置
MAX_UPLOAD_SIZE="10"
SUPPORTED_FILE_TYPES="jpg,jpeg,png,pdf,doc,docx"
DEFAULT_PAGE_SIZE="20"
MAX_PAGE_SIZE="100"
RATE_LIMIT_REQUESTS="100"
RATE_LIMIT_PERIOD="60"
MAINTENANCE_START="02:00"
MAINTENANCE_END="04:00"
BACKUP_SCHEDULE="0 2 * * *"
CLEANUP_SCHEDULE="0 4 * * *"

# 调试和开发
XDEBUG_ENABLED="true"
XDEBUG_HOST="localhost"
XDEBUG_PORT="9003"
TELESCOPE_ENABLED="true"
CLOCKWORK_ENABLED="false"
DEBUG_BAR_ENABLED="true"
QUERY_LOG_ENABLED="true"
SLOW_QUERY_THRESHOLD="1000"

